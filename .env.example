POSTGRES_DB=jere_platform
POSTGRES_USER=jere_platform
POSTGRES_PASSWORD=local_only_change_me
POSTGRES_PORT=5432
DATABASE_URL=jdbc:postgresql://localhost:5432/jere_platform
DATABASE_USERNAME=jere_platform
DATABASE_PASSWORD=local_only_change_me

# Required in production. Use at least 32 random bytes and keep it outside Git.
AUTH_JWT_SECRET=
AUTH_ACCESS_TOKEN_LIFETIME=PT15M
AUTH_REFRESH_TOKEN_LIFETIME=P30D
AUTH_REFRESH_COOKIE_SECURE=false

# Required only for the one-time /api/bootstrap/initialize operation.
PLATFORM_BOOTSTRAP_TOKEN=

# Optional until signed party-source exports are enabled. Use at least 32 random bytes.
PARTY_SOURCE_GESTUDIO_CURRENT_SECRET=
PARTY_SOURCE_GESTUDIO_PREVIOUS_SECRET=
PARTY_SOURCE_SCALARIS_CURRENT_SECRET=
PARTY_SOURCE_SCALARIS_PREVIOUS_SECRET=
